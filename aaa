在Spring Boot中根据请求路径的Path Variable动态调用不同的Service有多种优雅的实现方式。以下是几种常见的方法：

方法一：使用策略模式 + Spring Bean注册

1. 定义服务接口

```java
// Service接口定义
public interface DataService {
    String processData(String data);
    String getServiceType();
}

// 枚举定义服务类型
public enum ServiceType {
    USER("user"),
    ORDER("order"),
    PRODUCT("product");
    
    private final String type;
    
    ServiceType(String type) {
        this.type = type;
    }
    
    public String getType() {
        return type;
    }
    
    public static ServiceType fromString(String type) {
        for (ServiceType st : ServiceType.values()) {
            if (st.getType().equalsIgnoreCase(type)) {
                return st;
            }
        }
        throw new IllegalArgumentException("Unknown service type: " + type);
    }
}
```

2. 实现具体的服务

```java
// 用户服务
@Service
public class UserService implements DataService {
    
    @Override
    public String processData(String data) {
        return "Processing user data: " + data;
    }
    
    @Override
    public String getServiceType() {
        return ServiceType.USER.getType();
    }
}

// 订单服务
@Service
public class OrderService implements DataService {
    
    @Override
    public String processData(String data) {
        return "Processing order data: " + data;
    }
    
    @Override
    public String getServiceType() {
        return ServiceType.ORDER.getType();
    }
}

// 产品服务
@Service
public class ProductService implements DataService {
    
    @Override
    public String processData(String data) {
        return "Processing product data: " + data;
    }
    
    @Override
    public String getServiceType() {
        return ServiceType.PRODUCT.getType();
    }
}
```

3. 创建服务工厂

```java
@Component
public class ServiceFactory {
    
    private final Map<String, DataService> serviceMap = new ConcurrentHashMap<>();
    
    // 通过构造函数注入所有DataService实现
    @Autowired
    public ServiceFactory(List<DataService> services) {
        for (DataService service : services) {
            serviceMap.put(service.getServiceType().toLowerCase(), service);
        }
    }
    
    public DataService getService(String serviceType) {
        DataService service = serviceMap.get(serviceType.toLowerCase());
        if (service == null) {
            throw new IllegalArgumentException("Unknown service type: " + serviceType);
        }
        return service;
    }
}
```

4. 控制器实现

```java
@RestController
@RequestMapping("/api/v1")
public class DynamicController {
    
    private final ServiceFactory serviceFactory;
    
    @Autowired
    public DynamicController(ServiceFactory serviceFactory) {
        this.serviceFactory = serviceFactory;
    }
    
    @GetMapping("/process/{serviceType}")
    public ResponseEntity<?> processData(
            @PathVariable String serviceType,
            @RequestParam String data) {
        
        try {
            DataService service = serviceFactory.getService(serviceType);
            String result = service.processData(data);
            return ResponseEntity.ok(result);
        } catch (IllegalArgumentException e) {
            return ResponseEntity.badRequest().body(e.getMessage());
        }
    }
    
    // 带验证的版本
    @GetMapping("/process/validated/{serviceType}")
    public ResponseEntity<?> processDataValidated(
            @PathVariable @Pattern(regexp = "user|order|product") String serviceType,
            @RequestParam String data) {
        
        DataService service = serviceFactory.getService(serviceType);
        String result = service.processData(data);
        return ResponseEntity.ok(result);
    }
}
```

方法二：使用Map直接注入（更简洁）

```java
@Component
public class ServiceRegistry {
    
    @Autowired
    private Map<String, DataService> serviceMap;
    
    public DataService getService(String serviceType) {
        // 根据bean名称获取，假设bean名称为userService、orderService等
        String beanName = serviceType + "Service";
        DataService service = serviceMap.get(beanName);
        
        if (service == null) {
            throw new ServiceNotFoundException("Service not found for type: " + serviceType);
        }
        return service;
    }
}

// 自定义异常
public class ServiceNotFoundException extends RuntimeException {
    public ServiceNotFoundException(String message) {
        super(message);
    }
}
```

方法三：使用Spring的ApplicationContext

```java
@Component
public class ServiceLocator {
    
    private final ApplicationContext applicationContext;
    
    public ServiceLocator(ApplicationContext applicationContext) {
        this.applicationContext = applicationContext;
    }
    
    public DataService getService(String serviceType) {
        String beanName = serviceType + "Service";
        return applicationContext.getBean(beanName, DataService.class);
    }
    
    // 或者使用Qualifier
    public DataService getServiceByQualifier(String serviceType) {
        Map<String, DataService> beans = applicationContext.getBeansOfType(DataService.class);
        
        return beans.values().stream()
            .filter(service -> service.getServiceType().equals(serviceType))
            .findFirst()
            .orElseThrow(() -> new IllegalArgumentException("Service not found"));
    }
}
```

方法四：使用注解和AOP（最优雅）

1. 创建自定义注解

```java
@Target(ElementType.TYPE)
@Retention(RetentionPolicy.RUNTIME)
@Component
public @interface ServiceHandler {
    String value();
}
```

2. 修改服务实现

```java
@ServiceHandler("user")
@Service
public class UserService implements DataService {
    // 实现代码...
}

@ServiceHandler("order")
@Service
public class OrderService implements DataService {
    // 实现代码...
}
```

3. 创建注解处理器

```java
@Component
public class AnnotatedServiceFactory {
    
    private final Map<String, DataService> annotatedServices = new ConcurrentHashMap<>();
    
    @Autowired
    public AnnotatedServiceFactory(ApplicationContext applicationContext) {
        // 获取所有带有@ServiceHandler注解的bean
        Map<String, Object> beans = applicationContext.getBeansWithAnnotation(ServiceHandler.class);
        
        beans.forEach((beanName, bean) -> {
            if (bean instanceof DataService) {
                ServiceHandler annotation = bean.getClass().getAnnotation(ServiceHandler.class);
                annotatedServices.put(annotation.value(), (DataService) bean);
            }
        });
    }
    
    public DataService getService(String serviceType) {
        DataService service = annotatedServices.get(serviceType);
        if (service == null) {
            throw new IllegalArgumentException("No handler found for service type: " + serviceType);
        }
        return service;
    }
}
```

方法五：使用Spring的InitializingBean

```java
@Component
public class ServiceStrategy implements InitializingBean {
    
    @Autowired
    private List<DataService> services;
    
    private final Map<String, DataService> serviceMap = new HashMap<>();
    
    @Override
    public void afterPropertiesSet() {
        for (DataService service : services) {
            serviceMap.put(service.getServiceType(), service);
        }
    }
    
    public DataService getStrategy(String type) {
        return serviceMap.get(type);
    }
}
```

完整的使用示例

```java
@RestController
@RequestMapping("/api")
public class BusinessController {
    
    private final ServiceFactory serviceFactory;
    
    @Autowired
    public BusinessController(ServiceFactory serviceFactory) {
        this.serviceFactory = serviceFactory;
    }
    
    @PostMapping("/{serviceType}/create")
    public ResponseEntity<ApiResponse> create(
            @PathVariable String serviceType,
            @RequestBody Map<String, Object> data) {
        
        try {
            DataService service = serviceFactory.getService(serviceType);
            String result = service.processData(data.toString());
            
            return ResponseEntity.ok(
                ApiResponse.success("Success", result)
            );
        } catch (IllegalArgumentException e) {
            return ResponseEntity.badRequest().body(
                ApiResponse.error("Invalid service type: " + serviceType)
            );
        }
    }
    
    // 支持多个路径变量的情况
    @GetMapping("/{serviceType}/{action}")
    public ResponseEntity<?> handleAction(
            @PathVariable String serviceType,
            @PathVariable String action,
            @RequestParam(required = false) Map<String, String> params) {
        
        // 可以根据action进一步分发
        DataService service = serviceFactory.getService(serviceType);
        
        switch (action) {
            case "get":
                return ResponseEntity.ok(service.processData("Get operation"));
            case "update":
                return ResponseEntity.ok(service.processData("Update operation"));
            default:
                return ResponseEntity.badRequest().body("Unknown action");
        }
    }
}

// 统一响应格式
@Data
@AllArgsConstructor
class ApiResponse {
    private boolean success;
    private String message;
    private Object data;
    
    public static ApiResponse success(String message, Object data) {
        return new ApiResponse(true, message, data);
    }
    
    public static ApiResponse error(String message) {
        return new ApiResponse(false, message, null);
    }
}
```

