```java
// S3QueryServiceImpl.java
package com.example.duckdbdemo.service.impl;

import com.example.duckdbdemo.mapper.S3DataMapper;
import com.example.duckdbdemo.model.S3Data;
import com.example.duckdbdemo.service.S3QueryService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.sql.*;
import java.util.List;
import java.util.Map;

@Service
public class S3QueryServiceImpl implements S3QueryService {

    @Autowired
    private S3DataMapper s3DataMapper;
    
    @Autowired
    private DataSource dataSource;

    @Override
    public List<Map<String, Object>> queryParquetFromS3(String bucket, String filePath, int limit) {
        return s3DataMapper.queryParquetFile(bucket, filePath, limit);
    }

    @Override
    public List<Map<String, Object>> queryCsvFromS3(String bucket, String filePath, int limit) {
        return s3DataMapper.queryCsvFile(bucket, filePath, limit);
    }

    @Override
    public List<String> listS3Files(String bucket) {
        return s3DataMapper.listS3Files(bucket);
    }

    @Override
    public List<S3Data> queryWithConditions(String bucket, String filePattern, List<String> columns) {
        return s3DataMapper.queryS3Data(bucket, filePattern, columns);
    }

    @Override
    @Transactional
    public void createExternalTable(String bucket, String path) {
        try (Connection conn = dataSource.getConnection();
             Statement stmt = conn.createStatement()) {
            
            // 创建外部表视图
            String sql = String.format(
                "CREATE OR REPLACE VIEW s3_external_data AS " +
                "SELECT * FROM read_parquet('s3://%s/%s/*.parquet')",
                bucket, path
            );
            stmt.execute(sql);
            
        } catch (SQLException e) {
            throw new RuntimeException("Failed to create external table", e);
        }
    }

    // 使用原生JDBC执行复杂DuckDB查询
    public List<Map<String, Object>> executeComplexQuery(String sql) {
        try (Connection conn = dataSource.getConnection();
             Statement stmt = conn.createStatement();
             ResultSet rs = stmt.executeQuery(sql)) {
            
            ResultSetMetaData metaData = rs.getMetaData();
            int columnCount = metaData.getColumnCount();
            
            return JdbcUtils.resultSetToList(rs, metaData, columnCount);
            
        } catch (SQLException e) {
            throw new RuntimeException("Failed to execute query", e);
        }
    }
    
    // 使用DuckDB的COPY TO将查询结果写入S3
    public void exportToS3(String query, String s3Path) {
        try (Connection conn = dataSource.getConnection();
             Statement stmt = conn.createStatement()) {
            
            String copySql = String.format(
                "COPY (%s) TO '%s' (FORMAT PARQUET)",
                query, s3Path
            );
            stmt.execute(copySql);
            
        } catch (SQLException e) {
            throw new RuntimeException("Failed to export to S3", e);
        }
    }
}

// JDBC工具类
class JdbcUtils {
    static List<Map<String, Object>> resultSetToList(ResultSet rs, 
                                                     ResultSetMetaData metaData, 
                                                     int columnCount) throws SQLException {
        // 转换ResultSet为List<Map>
        // 实现略
        return List.of();
    }
}
