4. DuckDB配置类

```java
// DuckDBConfig.java
package com.example.duckdbdemo.config;

import org.duckdb.DuckDBConnection;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

import javax.sql.DataSource;
import java.sql.Connection;
import java.sql.SQLException;
import java.sql.Statement;
import java.util.Properties;

@Configuration
public class DuckDBConfig {

    @Value("${duckdb.database::memory:}")
    private String databasePath;

    @Value("${duckdb.s3.region:us-east-1}")
    private String s3Region;

    @Value("${duckdb.s3.access-key:}")
    private String s3AccessKey;

    @Value("${duckdb.s3.secret-key:}")
    private String s3SecretKey;

    @Value("${duckdb.s3.endpoint:}")
    private String s3Endpoint;

    @Value("${duckdb.httpfs.enabled:true}")
    private boolean httpfsEnabled;

    @Bean
    public DataSource duckDBDataSource() throws SQLException {
        // DuckDB JDBC URL
        String jdbcUrl = "jdbc:duckdb:" + databasePath;
        
        // 创建连接
        Properties properties = new Properties();
        DuckDBDataSource dataSource = new DuckDBDataSource(jdbcUrl, properties);
        
        // 初始化连接，配置S3
        initializeDuckDBConnection(dataSource);
        
        return dataSource;
    }

    private void initializeDuckDBConnection(DuckDBDataSource dataSource) throws SQLException {
        try (Connection conn = dataSource.getConnection();
             Statement stmt = conn.createStatement()) {
            
            // 安装和加载httpfs扩展（用于S3访问）
            if (httpfsEnabled) {
                try {
                    stmt.execute("INSTALL httpfs");
                    stmt.execute("LOAD httpfs");
                    System.out.println("HTTPFS extension loaded successfully");
                } catch (SQLException e) {
                    System.err.println("Failed to load HTTPFS extension: " + e.getMessage());
                }
            }
            
            // 设置S3配置
            if (!s3AccessKey.isEmpty() && !s3SecretKey.isEmpty()) {
                // 使用AK/SK认证
                stmt.execute("SET s3_region='" + s3Region + "'");
                stmt.execute("SET s3_access_key_id='" + s3AccessKey + "'");
                stmt.execute("SET s3_secret_access_key='" + s3SecretKey + "'");
                
                if (!s3Endpoint.isEmpty()) {
                    stmt.execute("SET s3_endpoint='" + s3Endpoint + "'");
                    // 对于MinIO等兼容S3的服务
                    stmt.execute("SET s3_url_style='path'");
                }
                
                // 可选：设置其他S3参数
                stmt.execute("SET s3_use_ssl=true");
                stmt.execute("SET s3_uploader_max_parts_per_file=1000");
                stmt.execute("SET s3_uploader_max_filesize=5368709120"); // 5GB
                
                System.out.println("S3 configuration set successfully");
            }
            
            // 设置其他DuckDB参数
            stmt.execute("SET threads TO 4");
            stmt.execute("SET memory_limit='2GB'");
            
        } catch (SQLException e) {
            throw new SQLException("Failed to initialize DuckDB connection", e);
        }
    }
}

// 自定义DuckDB数据源
class DuckDBDataSource extends org.springframework.jdbc.datasource.SimpleDriverDataSource {
    public DuckDBDataSource(String url, Properties properties) {
        setDriverClass(org.duckdb.DuckDBDriver.class);
        setUrl(url);
        setConnectionProperties(properties);
    }
}
```

