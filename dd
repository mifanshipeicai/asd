7. Mapper接口和XML

```java
// S3DataMapper.java
package com.example.duckdbdemo.mapper;

import com.example.duckdbdemo.model.S3Data;
import org.apache.ibatis.annotations.Mapper;
import org.apache.ibatis.annotations.Param;
import org.apache.ibatis.annotations.Select;

import java.util.List;
import java.util.Map;

@Mapper
public interface S3DataMapper {
    
    // 查询S3上的Parquet文件
    @Select("SELECT * FROM read_parquet('s3://#{bucket}/#{filePath}') LIMIT #{limit}")
    List<Map<String, Object>> queryParquetFile(
            @Param("bucket") String bucket,
            @Param("filePath") String filePath,
            @Param("limit") int limit);
    
    // 查询S3上的CSV文件
    @Select("SELECT * FROM read_csv_auto('s3://#{bucket}/#{filePath}') LIMIT #{limit}")
    List<Map<String, Object>> queryCsvFile(
            @Param("bucket") String bucket,
            @Param("filePath") String filePath,
            @Param("limit") int limit);
    
    // 列出S3桶中的文件（需要安装aws扩展）
    @Select("SELECT * FROM glob('s3://#{bucket}/*')")
    List<String> listS3Files(@Param("bucket") String bucket);
    
    // 动态SQL查询
    List<S3Data> queryS3Data(@Param("bucket") String bucket, 
                            @Param("filePattern") String filePattern,
                            @Param("columns") List<String> columns);
}
```

```xml
<!-- S3DataMapper.xml -->
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.duckdbdemo.mapper.S3DataMapper">
    
    <select id="queryS3Data" resultType="com.example.duckdbdemo.model.S3Data">
        SELECT 
        <choose>
            <when test="columns != null and columns.size() > 0">
                <foreach collection="columns" item="col" separator=",">
                    ${col}
                </foreach>
            </when>
            <otherwise>*</otherwise>
        </choose>
        FROM read_parquet('s3://${bucket}/${filePattern}')
        LIMIT 1000
    </select>
    
    <!-- 查询S3上的多个Parquet文件 -->
    <select id="queryMultipleParquetFiles" resultType="map">
        SELECT * 
        FROM read_parquet([
            <foreach collection="files" item="file" separator=",">
                's3://${bucket}/${file}'
            </foreach>
        ])
        WHERE ${condition}
        LIMIT #{limit}
    </select>
    
    <!-- 创建S3数据的外部表 -->
    <update id="createS3ExternalTable">
        CREATE OR REPLACE VIEW s3_data_view AS
        SELECT * FROM read_parquet('s3://${bucket}/${path}/*.parquet')
    </update>
</mapper>
