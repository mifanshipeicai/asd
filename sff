3. 查询路径优化

```java
@Component
public class OptimizedQueryService {
    
    // 方案A：并行查询（如果查询多个日期）
    public List<DataRecord> parallelQuery(List<LocalDate> dates, String condition) {
        return dates.parallelStream()
            .map(date -> querySingleDate(date, condition))
            .flatMap(List::stream)
            .collect(Collectors.toList());
    }
    
    // 方案B：按需加载，只查必要日期
    public List<DataRecord> optimizedQuery(LocalDate start, LocalDate end, 
                                           String condition) {
        List<LocalDate> datesToQuery = new ArrayList<>();
        
        // 先检查本地DuckDB
        for (LocalDate date = start; !date.isAfter(end); date = date.plusDays(1)) {
            if (!hasDataInLocal(date)) {
                datesToQuery.add(date);
            }
        }
        
        // 批量处理S3查询
        if (!datesToQuery.isEmpty()) {
            return batchQueryFromS3(datesToQuery, condition);
        }
        
        return queryFromLocal(start, end, condition);
    }
}
```

